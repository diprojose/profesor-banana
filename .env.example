# Configuración de Firebase (copia este archivo a `.env.local` y rellena
# los valores desde la consola: https://console.firebase.google.com
#   Configuración del proyecto → Tus apps → App web → Config
# Sin estos valores, la app funciona en modo local (sin cuentas ni nube).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
